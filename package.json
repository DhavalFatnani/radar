{
  "name": "radar",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:reset": "tsx src/db/reset.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:signals": "tsx src/db/seed-signals.ts",
    "db:seed:mappings": "tsx src/db/seed-mappings.ts",
    "db:seed:ops-signals": "tsx src/db/seed-ops-signals.ts",
    "db:source:tenders": "tsx src/db/source-tenders.ts",
    "db:source:jobs": "tsx src/db/source-jobs.ts",
    "db:source:leads": "tsx src/db/source-leads.ts",
    "db:brief:generate": "tsx src/db/brief-generate.ts",
    "db:contacts:resolve": "tsx src/db/resolve-contacts.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.3",
    "@ai-sdk/deepseek": "^3.0.2",
    "@ai-sdk/openai": "^4.0.4",
    "@ai-sdk/openai-compatible": "^3.0.2",
    "@ai-sdk/xai": "^4.0.3",
    "ai": "^7.0.8",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "next": "^15.5.19",
    "next-auth": "^5.0.0-beta.31",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "resend": "^6.16.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.19",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
