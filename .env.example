# Radar ŌĆö environment variables. Copy to .env.local and fill in. Never commit .env.local.

# Node environment: development | test | production
NODE_ENV=development

# Neon Postgres connection string (used from Slice 2 onward).
# Neon dashboard -> Connection Details -> pooled connection string.
# Optional in Slice 1; required once the data layer lands.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
# Direct (unpooled) Neon endpoint ŌĆö drizzle-kit migrations. Falls back to DATABASE_URL.
DIRECT_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
# Dedicated test database (a Neon branch, direct endpoint). Falls back to DIRECT_URL/DATABASE_URL.
TEST_DATABASE_URL=postgresql://USER:PASSWORD@HOST_test/DBNAME?sslmode=require

# --- Auth (Slice 3) ---
# Strong random secret for JWT signing. Generate: openssl rand -base64 33  (or: npx auth secret)
AUTH_SECRET=replace-with-a-strong-random-secret
# The single operator's login email.
OPERATOR_EMAIL=operator@example.com
# bcrypt hash of the operator password. Generate: node scripts/hash-password.mjs '<password>'
# The script escapes every `$` as `\$` (e.g. \$2b\$12\$...) so @next/env's
# dotenv-expand keeps the hash literal ŌĆö paste its output verbatim, do not unescape.
OPERATOR_PASSWORD_HASH=replace-with-bcrypt-hash

# --- LLM Providers (Phase 2 ┬Ę Slice 2.2a) ---
# Fallback order: free/local first. Set any combination; unconfigured providers
# are silently skipped. At least one must be configured to run interviews.
# Override the order with a CSV (default: ollama,deepseek,grok,openai,anthropic):
# AI_PROVIDER_ORDER=ollama,deepseek,grok,openai,anthropic

# Ollama (local, free) ŌĆö start ollama, pull a model, then set:
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434/v1

# DeepSeek ŌĆö https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat

# xAI / Grok ŌĆö https://console.x.ai/
# XAI_API_KEY=xai-...
# XAI_MODEL=grok-3-mini

# OpenAI ŌĆö https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Anthropic ŌĆö https://console.anthropic.com/
# ANTHROPIC_API_KEY=replace-with-anthropic-key
# ANTHROPIC_MODEL=claude-opus-4-8

# AI Gateway (optional, opt-in ŌĆö add 'gateway' to AI_PROVIDER_ORDER to use)
# AI_GATEWAY_API_KEY=...
# AI_GATEWAY_BASE_URL=https://your-gateway-url
# AI_GATEWAY_MODEL=provider/model-name

# Resend email sending (Outreach Slice B) ŌĆö https://resend.com/api-keys
# Both must be set to enable in-app sending. OUTREACH_FROM_EMAIL must be a bare
# address on a Resend-verified domain.
# RESEND_API_KEY=replace-with-resend-key
# OUTREACH_FROM_EMAIL=outreach@yourdomain.com

# Crustdata API key for live campaign sourcing (optional; get one at app.crustdata.com)
CRUSTDATA_API_KEY=
