# --- GitNexus (code-intelligence knowledge graph) ---
# The index itself: machine-specific, large (binary KuzuDB), rebuilt by
# `npx gitnexus analyze`. Never commit.
.gitnexus/

# GitNexus-generated agent context + skill files (regenerated on every analyze).
# Curated guidance lives in AGENTS.md, which IS tracked.
/CLAUDE.md
.claude/skills/gitnexus/

# --- Local machine state accidentally written into the repo ---
# agentmemory MCP DB written with an unexpanded "~" -> a literal ~/ dir here.
/~/
.agentmemory/

# --- Node / Next.js ---
/node_modules
/.next
/out
/build
next-env.d.ts
*.tsbuildinfo

# Env files (never commit real secrets; .env.example IS tracked)
.env
.env.local
.env.*.local

# Test / coverage output
/coverage

# SDD scratch (never commit)
.superpowers/
